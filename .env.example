# --- LLM model endpoints ---------------------------------------------------
PROTOGENIUS_LLM_PROVIDER=openai
PROTOGENIUS_LLM_MODEL=gpt-5
PROTOGENIUS_LLM_API_KEY=
PROTOGENIUS_LLM_BASE_URL=https://api.openai.com/v1

# --- MCP servers -----------------------------------------------------------
# arXiv MCP (preferred). May be a local stdio command or a remote URL.
PROTOGENIUS_ARXIV_MCP_URL=
# GitHub Copilot hosted MCP — see docs/mcp-integration.md
PROTOGENIUS_GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
PROTOGENIUS_GITHUB_TOKEN=

# --- Optional academic providers ------------------------------------------
PROTOGENIUS_SEMANTIC_SCHOLAR_API_KEY=
PROTOGENIUS_OPENALEX_EMAIL=

# --- Run controls (override quotas.yaml at runtime if set) ----------------
PROTOGENIUS_MAX_TURNS=
PROTOGENIUS_MAX_SEARCH_RESULTS=
PROTOGENIUS_MAX_TOKENS=
PROTOGENIUS_MAX_WALLTIME_SECS=
