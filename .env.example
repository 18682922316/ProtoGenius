# ProtoGenius environment variables.
#
# ProtoGenius supports two operating modes — see docs/usage.md §"Two modes".
#
#   Mode A — Cursor Cloud Agent (default delivery form)
#     The Cursor agent itself is the LLM; nothing in this file is REQUIRED
#     to start a task. You only set the variables for the research streams
#     you want to enable (arXiv MCP, GitHub MCP, etc.).
#
#   Mode B — Standalone Python CLI (`protogenius run ...`)
#     The Python orchestrator drives the pipeline itself, so you MUST
#     provide an LLM API key in addition to whatever research credentials
#     you need.
#
# Variables marked [REQUIRED-B] are mandatory for mode B but ignored in
# mode A. Variables marked [optional] are safe to leave empty.

# ===========================================================================
# 1. LLM endpoint (Mode B only — Cursor mode uses the IDE's subscribed model)
# ===========================================================================

# [REQUIRED-B]  Auth token for the configured LLM provider.
#               Read by protogenius.llm.BaseHttpLLMClient at call time.
PROTOGENIUS_LLM_API_KEY=

# [optional]    Override the provider base URL (defaults to OpenAI).
#               Read by protogenius.llm.BaseHttpLLMClient.
PROTOGENIUS_LLM_BASE_URL=https://api.openai.com/v1

# To change provider / model name, edit `config/default.yaml` (the
# `llm.provider` and `llm.model` keys) or pass --config <override.yaml>.
# Tip — to opt OUT of the standalone Python LLM client when running in
# Cursor mode, set in your override file:
#     llm:
#       provider: cursor
# This installs an inert client that raises a clear error if anything
# accidentally calls it.

# ===========================================================================
# 2. Research credentials  (used by mode A AND mode B when enabled)
# ===========================================================================

# [optional]    arXiv MCP endpoint (HTTP). Either set this OR define a
#               stdio command in config/default.yaml -> mcp.arxiv.command.
#               If neither is set, the arXiv adapter will raise at call
#               time; Semantic Scholar + OpenAlex still work.
PROTOGENIUS_ARXIV_MCP_URL=

# [optional, strongly recommended]  GitHub PAT used to authenticate against
#               the Copilot-hosted MCP. Without it the adapter falls back
#               to anonymous calls, which the endpoint will reject.
PROTOGENIUS_GITHUB_TOKEN=

# [optional]    Semantic Scholar API key — joining the polite pool avoids
#               aggressive rate-limiting on the anonymous tier.
PROTOGENIUS_SEMANTIC_SCHOLAR_API_KEY=

# [optional]    OpenAlex contact email (their `mailto=` polite-pool
#               parameter). Speeds up requests but is not required.
PROTOGENIUS_OPENALEX_EMAIL=

# ===========================================================================
# 3. Quota overrides  (optional; default values live in config/quotas.yaml)
# ===========================================================================
# These are scalar shortcuts wired in protogenius.config._apply_env_overrides.
# Leave empty to inherit the frozen v1 hard caps (50 / 100 / 1_000_000 /
# 21600). Setting a value here LOWERS the cap for one run — you cannot
# raise it above the v1 contract; the schema rejects values that would
# break the frozen contract.

PROTOGENIUS_MAX_TURNS=
PROTOGENIUS_MAX_SEARCH_RESULTS=
PROTOGENIUS_MAX_TOKENS=
PROTOGENIUS_MAX_WALLTIME_SECS=
